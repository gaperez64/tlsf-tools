# Static analysis for the hand-written sources only. The flex/bison-generated
# tlsf_lex.* / tlsf_parse.* live in the build dir and are excluded by
# HeaderFilterRegex (which only matches our own headers).
Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  performance-*,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-isolate-declaration,
  -readability-identifier-naming,
  -readability-non-const-parameter,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -cert-err33-c,
  -cert-dcl03-c,
  -misc-include-cleaner,
  -clang-analyzer-deadcode.DeadStores

HeaderFilterRegex: 'include/tlsf/.*\.h$'
WarningsAsErrors: ''
