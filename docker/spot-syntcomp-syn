#!/bin/sh
# spot-syntcomp-syn — TLSF *synthesis* via the tlsf-tools decomposed-synthesis
# preprocessor (templates + in-process OxiDD safety/GR(1) solvers) with ltlsynt
# as the residual liveness backend.  Mirrors the SYNTCOMP contract that the
# upstream `ltlsynt --tlsf` wrappers honour:
#
#   realizable    -> "REALIZABLE" then the AIGER controller (aag), exit 0
#   unrealizable  -> "UNREALIZABLE",                                exit 1
#   inconclusive  -> diagnostics on stderr, no verdict,            exit 2
#
# tlsf-solve emits the raw AIGER file (exit 0) and signals an unrealizable
# cluster on stderr (exit 1); this wrapper adds the REALIZABLE / UNREALIZABLE
# line the competition expects.  A backend failure or timeout is reported as
# inconclusive rather than a (possibly wrong) verdict.
#
# Usage: spot-syntcomp-syn SPEC.tlsf
set -u
: "${LTLSYNT:=ltlsynt}"

aig=$(mktemp)
err=$(mktemp)
trap 'rm -f "$aig" "$err"' EXIT INT TERM

if tlsf-solve --solver "$LTLSYNT" --output "$aig" "$@" 2>"$err"; then
  echo REALIZABLE
  cat "$aig"
  exit 0
fi

if grep -q 'UNREALIZABLE' "$err"; then
  echo UNREALIZABLE
  exit 1
fi

# Backend failure / timeout / parse error: surface diagnostics, emit no verdict.
cat "$err" >&2
exit 2
