INFO {
  TITLE: "cluster_prune"
  DESCRIPTION: "liveness assumption G F !r dropped from the safety cluster (class lever, even though it shares r) and from the disjoint liveness cluster (cone of influence)"
  SEMANTICS: Mealy
  TARGET: Mealy
}
MAIN {
  INPUTS { r; }
  OUTPUTS { g; h; }
  ASSUME {
    G F (!r);
  }
  GUARANTEE {
    G (r -> X g);
    G F h;
  }
}
