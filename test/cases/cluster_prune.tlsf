INFO {
  TITLE: "cluster_prune"
  DESCRIPTION: "liveness assumption G F !r is kept on the safety cluster that shares r and pruned only from disjoint clusters"
  SEMANTICS: Mealy
  TARGET: Mealy
}
MAIN {
  INPUTS { r; }
  OUTPUTS { g; h; }
  ASSUME {
    G F (!r);
  }
  GUARANTEE {
    G (r -> X g);
    G F h;
  }
}
