INFO {
  TITLE:       "expand test";
  DESCRIPTION: "params, buses, bounded quantifiers, SIZEOF";
  SEMANTICS:   Mealy;
  TARGET:      Mealy;
}

MAIN {

  INPUTS {
    r_0;
    r_1;
    r_2;
  }

  OUTPUTS {
    g_0;
    g_1;
    g_2;
  }

    ASSUME {
      ((G ((r_0 -> F (!(r_0)))) && G ((r_1 -> F (!(r_1))))) && G ((r_2 -> F (!(r_2)))));
    }

    GUARANTEE {
      ((G ((r_0 -> F (g_0))) && G ((r_1 -> F (g_1)))) && G ((r_2 -> F (g_2))));
      G (((g_0 || g_1) || g_2));
    }

}
