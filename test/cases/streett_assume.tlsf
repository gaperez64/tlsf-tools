INFO {
  TITLE: "streett-assume"
  DESCRIPTION: "Coupled (mutex) + assumption-dependent 2-pair Streett: a_k is only allowed while i_k, so G F a_k genuinely needs G F i_k.  Not solvable by GR(1) nor by an unconditional/response sufficient strategy."
  SEMANTICS: Mealy
  TARGET: Mealy
}
MAIN {
  INPUTS { i0; i1; }
  OUTPUTS { a0; a1; }
  GUARANTEE {
    G (!(a0 && a1));
    G (a0 -> i0);
    G (a1 -> i1);
    G F i0 -> G F a0;
    G F i1 -> G F a1;
  }
}
